# Copy this to .env and fill in your keys
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Set a strong random secret for admin promotion (required)
ADMIN_SECRET=change-me-to-a-strong-random-secret

# Database (leave empty for SQLite, set for PostgreSQL)
# Example: DATABASE_URL=postgresql://user:pass@localhost:5432/universaldoc
DATABASE_URL=
